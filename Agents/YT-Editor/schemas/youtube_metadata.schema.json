{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "YouTube Metadata",
  "type": "object",
  "required": ["description"],
  "properties": {
    "title_candidates": {
      "type": "array",
      "items": { "type": "string" }
    },
    "description": { "type": "string", "minLength": 1 },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hook Segments",
  "type": "object",
  "required": ["hooks"],
  "properties": {
    "hooks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "start_seconds", "end_seconds", "score", "reason", "transcript"],
        "properties": {
          "id": { "type": "string" },
          "start_seconds": { "type": "number", "minimum": 0 },
          "end_seconds": { "type": "number", "minimum": 0 },
          "score": { "type": "number", "minimum": 0, "maximum": 1 },
          "reason": { "type": "string" },
          "transcript": { "type": "string" }
        }
      }
    }
  }
}
